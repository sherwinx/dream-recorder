# Obtain from Google AI Studio
GEMINI_API_KEY=your-gemini-api-key-here

# Google Cloud Speech-to-Text project and service account credentials
GOOGLE_CLOUD_PROJECT=your-google-cloud-project-id
GOOGLE_APPLICATION_CREDENTIALS=/app/secrets/google-service-account.json

# Obtain from Luma Labs dashboard
LUMALABS_API_KEY=your-luma-labs-api-key-here

# Port to run the server on
PORT=5000
